<Window x:Class="QingLi.Windows.Views.CalendarPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" ShowInTaskbar="False"
        Width="1040" Height="520" MinWidth="760" MinHeight="420"
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="Manual" SnapsToDevicePixels="True"
        PreviewKeyDown="OnPreviewKeyDown" Loaded="OnLoaded" Deactivated="OnDeactivated">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Width" Value="30"/><Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,0,0,0"/><Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDE4EF"/><Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF5968"/>
        </Style>
    </Window.Resources>

    <Grid>
    <Border Margin="8" Background="#F8FAFD" BorderBrush="#1A0F172A" BorderThickness="1" CornerRadius="18">
        <Border.Effect><DropShadowEffect BlurRadius="26" Color="#40000000" ShadowDepth="0" Opacity="0.24"/></Border.Effect>
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/><ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/><ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="HistoryColumn" Grid.Column="0" Padding="14" Background="White" CornerRadius="14" BorderBrush="#160F172A" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="历史上的今天"/>
                        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="13" Foreground="#8A94A6" Text="{Binding SelectedDate, StringFormat={}{0:M月d日}}"/>
                    </DockPanel>
                    <ScrollViewer x:Name="HistoryScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding HistoryToday}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,4,8" Padding="0" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Click="OnHistoryClick" Tag="{Binding SourceUrl}">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Margin="0,1,8,0" Padding="6,3" VerticalAlignment="Top" Background="#EAF2FF" CornerRadius="7">
                                                <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#3977E8" Text="{Binding Year, StringFormat={}{0}年}"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" FontSize="14" Foreground="#313A49" TextWrapping="Wrap" Text="{Binding Summary}"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border x:Name="CalendarColumn" Grid.Column="2" Padding="12" Background="White" CornerRadius="14" BorderBrush="#160F172A" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="108"/><RowDefinition Height="40"/><RowDefinition Height="30"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="86"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="#FF5968" Text="{Binding Almanac.WeekdayText}"/>
                            <TextBlock Margin="0,-3,0,0" HorizontalAlignment="Center" FontSize="52" FontWeight="Bold" Foreground="#111827" Text="{Binding Almanac.DayNumber}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock FontSize="15" Foreground="#697386" Text="{Binding Almanac.LunarMonthDay, StringFormat=农历{0}}"/>
                            <TextBlock Margin="0,3,0,0" FontSize="13" Foreground="#8A94A6" Text="{Binding Almanac.GanZhiText}"/>
                            <TextBlock Margin="0,3,0,0" FontSize="13" Foreground="#8A94A6" Text="{Binding Almanac.ZodiacText}"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal"><Border Padding="5,2" Background="#EBF3FF" CornerRadius="8"><TextBlock Foreground="#3977E8" FontWeight="Bold" Text="宜"/></Border><ItemsControl Margin="5,0,0,0" ItemsSource="{Binding Almanac.Suitable}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><TextBlock Margin="0,0,4,0" FontSize="12" Foreground="#526172" Text="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"><Border Padding="5,2" Background="#FFF0F1" CornerRadius="8"><TextBlock Foreground="#E85462" FontWeight="Bold" Text="忌"/></Border><ItemsControl Margin="5,0,0,0" ItemsSource="{Binding Almanac.Avoid}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><TextBlock Margin="0,0,4,0" FontSize="12" Foreground="#526172" Text="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <DockPanel Grid.Row="1">
                        <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="#202736" Text="{Binding Calendar.DisplayMonth, StringFormat={}{0:yyyy年 M月}}"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource NavButton}" Content="‹" Command="{Binding PreviousMonthCommand}"/>
                            <Button Width="48" Height="28" Margin="5,0,1,0" Background="White" BorderBrush="#DDE4EF" Content="今天" Command="{Binding TodayCommand}"/>
                            <Button Style="{StaticResource NavButton}" Content="›" Command="{Binding NextMonthCommand}"/>
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Calendar.WeekdayHeaders}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate><DataTemplate><TextBlock x:Name="Header" HorizontalAlignment="Center" FontSize="13" Foreground="#768094" Text="{Binding Text}"/><DataTemplate.Triggers><DataTrigger Binding="{Binding IsWeekend}" Value="True"><Setter TargetName="Header" Property="Foreground" Value="#FF5968"/></DataTrigger></DataTemplate.Triggers></DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ListBox x:Name="CalendarDaysList" Grid.Row="3" ItemsSource="{Binding Calendar.Days}" SelectedItem="{Binding Calendar.SelectedDay, Mode=TwoWay}" SelectionChanged="OnCalendarSelectionChanged" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="7" Rows="6"/></ItemsPanelTemplate></ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Margin" Value="2"/><Setter Property="Padding" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="VerticalContentAlignment" Value="Stretch"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Cell" Padding="3,2" Background="Transparent" CornerRadius="10"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsSelected" Value="True"><Setter TargetName="Cell" Property="Background" Value="#E5EEFF"/></Trigger><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Cell" Property="Background" Value="#F0F5FF"/></Trigger><DataTrigger Binding="{Binding IsCurrentMonth}" Value="False"><Setter TargetName="Cell" Property="Opacity" Value="0.34"/></DataTrigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style></ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate><DataTemplate><Grid><TextBlock x:Name="Day" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="17" Foreground="#222A38" Text="{Binding Date.Day}"/><TextBlock x:Name="Sub" Margin="0,21,0,0" HorizontalAlignment="Center" FontSize="11" Foreground="#778196" Text="{Binding SecondaryText}"/><Border x:Name="Rest" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="3,0" Background="#FF5968" CornerRadius="5" Visibility="Collapsed"><TextBlock FontSize="11" Foreground="White" Text="休"/></Border><Border x:Name="Work" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="3,0" Background="#6B7A90" CornerRadius="5" Visibility="Collapsed"><TextBlock FontSize="11" Foreground="White" Text="班"/></Border></Grid><DataTemplate.Triggers><DataTrigger Binding="{Binding IsWeekend}" Value="True"><Setter TargetName="Day" Property="Foreground" Value="#FF5968"/></DataTrigger><DataTrigger Binding="{Binding HasSolarTerm}" Value="True"><Setter TargetName="Sub" Property="Foreground" Value="#3977E8"/></DataTrigger><DataTrigger Binding="{Binding IsRestDay}" Value="True"><Setter TargetName="Rest" Property="Visibility" Value="Visible"/></DataTrigger><DataTrigger Binding="{Binding IsMakeupWorkday}" Value="True"><Setter TargetName="Work" Property="Visibility" Value="Visible"/></DataTrigger></DataTemplate.Triggers></DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border x:Name="UpcomingColumn" Grid.Column="4" Padding="14" Background="White" CornerRadius="14" BorderBrush="#160F172A" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="最近节日节气"/>
                    <ScrollViewer x:Name="UpcomingScrollViewer" Grid.Row="1" Margin="0,10,0,8" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding UpcomingEvents}">
                            <ItemsControl.ItemTemplate><DataTemplate><Button Margin="0,0,4,7" Padding="7" Background="#FAFBFD" BorderBrush="#E7EBF2" HorizontalContentAlignment="Stretch" Click="OnUpcomingClick" Tag="{Binding}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#344154" Text="{Binding Title}"/><TextBlock Margin="0,2,0,0" FontSize="12" Foreground="#8A94A6" Text="{Binding DateText}"/></StackPanel><Border Grid.Column="1" Padding="8,3" VerticalAlignment="Center" Background="#EAF2FF" CornerRadius="8"><TextBlock FontSize="12" Foreground="#3977E8" Text="{Binding CountdownText}"/></Border></Grid></Button></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                        <Button x:Name="AddBirthdayButton" Margin="0,0,5,0" Padding="5" Content="＋生日" Click="OnAddBirthdayClick"/>
                        <Button x:Name="AddAnniversaryButton" Grid.Column="1" Margin="0,0,5,0" Padding="5" Content="＋纪念日" Click="OnAddAnniversaryClick"/>
                        <Button x:Name="SettingsButton" Grid.Column="2" Padding="5" Content="⚙" Click="OnSettingsClick"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>

        <Border x:Name="DragHandle" Height="28" VerticalAlignment="Top"
                Background="Transparent" Cursor="SizeAll"
                ToolTip="Drag to move window"
                AutomationProperties.Name="Window drag handle"
                AutomationProperties.HelpText="Drag to move the calendar window"
                MouseLeftButtonDown="OnDragHandleMouseLeftButtonDown">
            <Border x:Name="DragHandleAffordance" Width="44" Height="4"
                    Background="#66768094" CornerRadius="2" IsHitTestVisible="False"/>
        </Border>
        <Path x:Name="ResizeGrip" Width="14" Height="14" Margin="0,0,13,13"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              IsHitTestVisible="False" Stroke="#708A94A6" StrokeThickness="1.5"
              Data="M 0,14 L 14,0 M 6,14 L 14,6"/>
    </Grid>
</Window>
