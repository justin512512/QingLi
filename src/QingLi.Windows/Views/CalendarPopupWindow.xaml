<Window x:Class="QingLi.Windows.Views.CalendarPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="680"
        Height="470"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        SnapsToDevicePixels="True"
        PreviewKeyDown="OnPreviewKeyDown"
        Loaded="OnLoaded"
        Deactivated="OnDeactivated">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DDE4EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
        </Style>
    </Window.Resources>

    <Border Margin="8"
            Background="#FCFDFE"
            BorderBrush="#160F172A"
            BorderThickness="1"
            CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Color="#35000000" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="20,18" Background="#F9FBFF" CornerRadius="14">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#FF5968"
                               Text="{Binding SelectedDay.WeekdayText}" />
                    <TextBlock Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               FontSize="58"
                               FontWeight="Bold"
                               Foreground="#111827"
                               Text="{Binding SelectedDay.Date.Day}" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="14"
                               Foreground="#7B8496"
                               Text="{Binding SelectedDay.LunarText, StringFormat=农历{0}}" />
                    <TextBlock Margin="0,5,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="#9AA3B3"
                               Text="{Binding SelectedDay.Date, StringFormat={}{0:yyyy年M月d日}}" />

                    <Border Margin="0,18,0,14" Height="1" Background="#D9E0EB" />

                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#8A94A6" Text="节气与节日" />
                    <WrapPanel Margin="0,8,0,0">
                        <Border Margin="0,0,6,6" Padding="9,5" Background="#EAF2FF" CornerRadius="10">
                            <TextBlock FontSize="12" Foreground="#3977E8" Text="{Binding SelectedDay.SolarTerm, TargetNullValue=暂无节气}" />
                        </Border>
                        <Border Margin="0,0,6,6" Padding="9,5" Background="#FFF0F1" CornerRadius="10">
                            <TextBlock FontSize="12" Foreground="#E85462" Text="{Binding SelectedDay.HolidayName, TargetNullValue=暂无节日}" />
                        </Border>
                    </WrapPanel>

                    <TextBlock Margin="0,12,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#8A94A6" Text="生日提醒" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SelectedDay.Birthdays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,6,6" Padding="9,5" Background="#F2ECFF" CornerRadius="10">
                                    <TextBlock FontSize="12" Foreground="#7651C9" Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#A1A8B5"
                               Text="轻历仅展示真实节气、节假日和本地生日数据。" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="0,14" Background="#E2E7F0" />

            <Grid Grid.Column="2" Margin="20,14,14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#202736"
                               Text="{Binding DisplayMonth, StringFormat={}{0:yyyy年 M月}}" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource NavButton}" Content="‹" Command="{Binding PreviousMonthCommand}" />
                        <Button Width="54" Height="32" Margin="6,0,2,0" Background="#FFFFFF" BorderBrush="#DDE4EF" Content="今天" Command="{Binding TodayCommand}" />
                        <Button Style="{StaticResource NavButton}" Content="›" Command="{Binding NextMonthCommand}" />
                    </StackPanel>
                </DockPanel>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding WeekdayHeaders}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="7" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock x:Name="HeaderText" HorizontalAlignment="Center" Foreground="#768094" Text="{Binding Text}" />
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsWeekend}" Value="True"><Setter TargetName="HeaderText" Property="Foreground" Value="#FF5968" /></DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Days}"
                         SelectedItem="{Binding SelectedDay, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="7" Rows="6" /></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="3" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Cell" Padding="4,3" Background="Transparent" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Cell" Property="Background" Value="#E5EEFF" /></Trigger>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Cell" Property="Background" Value="#F0F5FF" /></Trigger>
                                            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False"><Setter TargetName="Cell" Property="Opacity" Value="0.34" /></DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <TextBlock x:Name="DayNumber" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Foreground="#222A38" Text="{Binding Date.Day}" />
                                <TextBlock x:Name="SubText" Grid.Row="1" HorizontalAlignment="Center" FontSize="10" Foreground="#778196" Text="{Binding SecondaryText}" />
                                <Border x:Name="TodayDot" Width="5" Height="5" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#4D82F7" CornerRadius="3" Visibility="Collapsed" />
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsWeekend}" Value="True"><Setter TargetName="DayNumber" Property="Foreground" Value="#FF5968" /></DataTrigger>
                                <DataTrigger Binding="{Binding IsToday}" Value="True"><Setter TargetName="TodayDot" Property="Visibility" Value="Visible" /><Setter TargetName="DayNumber" Property="FontWeight" Value="Bold" /></DataTrigger>
                                <DataTrigger Binding="{Binding HasSolarTerm}" Value="True"><Setter TargetName="SubText" Property="Foreground" Value="#3977E8" /></DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>
