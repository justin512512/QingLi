<Window x:Class="QingLi.Windows.Views.AnniversaryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:QingLi.Core.Anniversaries;assembly=QingLi.Core"
        Title="纪念日" Width="480" Height="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F5F6F8">
    <Grid Margin="20">
        <Border Padding="24" Background="White" BorderBrush="#14000000" BorderThickness="1" CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="#1F1F1F" Text="纪念日信息"/>
                    <TextBlock Margin="0,8,0,0" Foreground="#6A6A6A" Text="支持公历和农历提醒，保存前会自动校验。"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" Margin="0,20" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6" Text="名称"/>
                        <TextBox Margin="0,0,0,14" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="0,0,0,6" Text="日期类型"/>
                        <ComboBox Margin="0,0,0,14" SelectedValue="{Binding CalendarKind}" SelectedValuePath="Tag">
                            <ComboBoxItem Content="公历" Tag="{x:Static core:AnniversaryCalendarKind.Gregorian}"/>
                            <ComboBoxItem Content="农历" Tag="{x:Static core:AnniversaryCalendarKind.Lunar}"/>
                        </ComboBox>
                        <UniformGrid Columns="3" Margin="0,0,0,14">
                            <StackPanel Margin="0,0,12,0"><TextBlock Margin="0,0,0,6" Text="开始年份"/><TextBox Text="{Binding StartYearText}"/></StackPanel>
                            <StackPanel Margin="0,0,12,0"><TextBlock Margin="0,0,0,6" Text="月份"/><TextBox Text="{Binding MonthText}"/></StackPanel>
                            <StackPanel><TextBlock Margin="0,0,0,6" Text="日期"/><TextBox Text="{Binding DayText}"/></StackPanel>
                        </UniformGrid>
                        <CheckBox Margin="0,0,0,14" Content="闰月" IsChecked="{Binding IsLeapMonth}"/>
                        <UniformGrid Columns="2" Margin="0,0,0,14">
                            <StackPanel Margin="0,0,12,0"><TextBlock Margin="0,0,0,6" Text="提前天数"/><TextBox Text="{Binding ReminderDaysBeforeText}"/></StackPanel>
                            <StackPanel><TextBlock Margin="0,0,0,6" Text="提醒时间"/><TextBox Text="{Binding ReminderTimeText}"/></StackPanel>
                        </UniformGrid>
                        <TextBlock Margin="0,0,0,6" Text="备注"/>
                        <TextBox Height="80" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Notes}"/>
                        <CheckBox Margin="0,14,0,0" Content="启用提醒" IsChecked="{Binding IsEnabled}"/>
                        <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding ValidationErrors}">
                            <ItemsControl.ItemTemplate><DataTemplate><TextBlock Margin="0,0,0,6" Foreground="#C24532" Text="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Margin="0,8,0,0" Foreground="#C24532" Text="{Binding SaveErrorMessage}"/>
                    </StackPanel>
                </ScrollViewer>
                <DockPanel Grid.Row="2" LastChildFill="False">
                    <Button Width="96" Padding="0,10" Content="取消" Click="OnCancelClick"/>
                    <Button DockPanel.Dock="Right" Width="120" Padding="0,10" Content="保存" Click="OnSaveClick"/>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
