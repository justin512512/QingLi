<Window x:Class="QingLi.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:QingLi.Core.Settings;assembly=QingLi.Core"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="设置"
        Width="620"
        Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">
    <Grid Margin="20">
        <Border Padding="24"
                Background="White"
                BorderBrush="#14000000"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#1F1F1F"
                               Text="设置" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#6A6A6A"
                               Text="主题、时钟显示和启动方式都会保存在本地。" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,20,0,20"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6" Text="主题" />
                        <ComboBox Margin="0,0,0,14"
                                  SelectedValue="{Binding Theme}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="自动" Tag="{x:Static core:AppTheme.System}" />
                            <ComboBoxItem Content="浅色" Tag="{x:Static core:AppTheme.Light}" />
                            <ComboBoxItem Content="深色" Tag="{x:Static core:AppTheme.Dark}" />
                        </ComboBox>

                        <CheckBox Margin="0,0,0,14"
                                  Content="使用 12 小时制"
                                  IsChecked="{Binding UseTwelveHourClock}" />

                        <TextBlock Margin="0,0,0,6" Text="日期格式" />
                        <TextBox Margin="0,0,0,14"
                                 Text="{Binding DateFormat, UpdateSourceTrigger=PropertyChanged}" />

                        <UniformGrid Columns="2" Margin="0,0,0,14">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Margin="0,0,0,6" Text="时钟字号" />
                                <TextBox Text="{Binding ClockFontSizeText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Margin="0,0,0,6" Text="一周首日" />
                                <ComboBox SelectedValue="{Binding FirstDayOfWeek}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="周一" Tag="{x:Static sys:DayOfWeek.Monday}" />
                                    <ComboBoxItem Content="周日" Tag="{x:Static sys:DayOfWeek.Sunday}" />
                                    <ComboBoxItem Content="周六" Tag="{x:Static sys:DayOfWeek.Saturday}" />
                                </ComboBox>
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Margin="0,0,0,6" Text="时钟文字颜色" />
                        <TextBox Margin="0,0,0,8"
                                 IsEnabled="{Binding CanCustomizeClockTextColor}"
                                 Text="{Binding ClockTextColor, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,0,0,14"
                                   Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                   Text="{Binding EffectiveClockTextColor, StringFormat=当前颜色：{0}}" />

                        <ItemsControl Margin="0,0,0,14"
                                      ItemsSource="{Binding ValidationErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10,8"
                                            Background="#FFF4F1"
                                            CornerRadius="10">
                                        <TextBlock Foreground="#C24532" Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Margin="0,0,0,14"
                                Padding="10,8"
                                Background="#FFF4F1"
                                CornerRadius="10">
                            <TextBlock Foreground="#C24532"
                                       Text="{Binding SaveErrorMessage}" />
                        </Border>

                        <Border Margin="0,0,0,14"
                                Padding="12"
                                Background="#F5F7FA"
                                CornerRadius="12">
                            <StackPanel>
                                <CheckBox Content="开机启动"
                                          IsChecked="{Binding StartWithWindows}" />
                                <Button Margin="0,12,0,0"
                                        Padding="14,8"
                                        HorizontalAlignment="Left"
                                        Content="打开数据目录"
                                        Click="OnOpenDataDirectoryClick" />
                            </StackPanel>
                        </Border>

                        <Border Padding="12"
                                Background="#F8F3FF"
                                CornerRadius="12">
                            <StackPanel>
                                <CheckBox Content="替换系统时钟"
                                          IsChecked="False"
                                          IsEnabled="{Binding CanReplaceSystemClock}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#6E58A8"
                                           Text="{Binding ReplaceSystemClockMessage}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,14,0,0"
                                   Foreground="#6A6A6A"
                                   Text="高对比度模式下会自动禁用自定义颜色并使用系统颜色。" />
                    </StackPanel>
                </ScrollViewer>

                <DockPanel Grid.Row="2" LastChildFill="False">
                    <Button Width="96"
                            Padding="0,10"
                            Content="关闭"
                            Click="OnCloseClick" />
                    <Button DockPanel.Dock="Right"
                            Width="120"
                            Padding="0,10"
                            Content="保存"
                            Click="OnSaveClick" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
