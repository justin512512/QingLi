<Window x:Class="QingLi.Windows.Views.BirthdayEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:QingLi.Core.Birthdays;assembly=QingLi.Core"
        Title="生日"
        Width="480"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F6F8">
    <Grid Margin="20">
        <Border Padding="24"
                Background="White"
                BorderBrush="#14000000"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#1F1F1F"
                               Text="生日信息" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#6A6A6A"
                               Text="支持公历和农历提醒，保存前会自动校验。" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,20,0,20"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6" Text="姓名" />
                        <TextBox Margin="0,0,0,14"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,0,6" Text="日期类型" />
                        <ComboBox Margin="0,0,0,14"
                                  SelectedValue="{Binding CalendarKind}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="公历" Tag="{x:Static core:BirthdayCalendarKind.Gregorian}" />
                            <ComboBoxItem Content="农历" Tag="{x:Static core:BirthdayCalendarKind.Lunar}" />
                        </ComboBox>

                        <UniformGrid Columns="3" Margin="0,0,0,14">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Margin="0,0,0,6" Text="出生年" />
                                <TextBox Text="{Binding BirthYearText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Margin="0,0,0,6" Text="月份" />
                                <TextBox Text="{Binding MonthText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Margin="0,0,0,6" Text="日期" />
                                <TextBox Text="{Binding DayText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <CheckBox Margin="0,0,0,14"
                                  Content="闰月"
                                  IsChecked="{Binding IsLeapMonth}" />

                        <UniformGrid Columns="2" Margin="0,0,0,14">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Margin="0,0,0,6" Text="提前天数" />
                                <TextBox Text="{Binding ReminderDaysBeforeText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Margin="0,0,0,6" Text="提醒时间" />
                                <TextBox Text="{Binding ReminderTimeText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Margin="0,0,0,6" Text="备注" />
                        <TextBox Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Margin="0,14,0,0"
                                  Content="启用提醒"
                                  IsChecked="{Binding IsEnabled}" />

                        <ItemsControl Margin="0,16,0,0"
                                      ItemsSource="{Binding ValidationErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10,8"
                                            Background="#FFF4F1"
                                            CornerRadius="10">
                                        <TextBlock Foreground="#C24532" Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Margin="0,8,0,0"
                                Padding="10,8"
                                Background="#FFF4F1"
                                CornerRadius="10">
                            <TextBlock Foreground="#C24532"
                                       Text="{Binding SaveErrorMessage}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <DockPanel Grid.Row="2" LastChildFill="False">
                    <Button Width="96"
                            Padding="0,10"
                            Content="取消"
                            Click="OnCancelClick" />
                    <Button DockPanel.Dock="Right"
                            Width="120"
                            Padding="0,10"
                            Content="保存"
                            Click="OnSaveClick" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
